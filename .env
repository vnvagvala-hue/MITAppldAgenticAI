# Yahoo Finance Configuration
YAHOO_FINANCE_TIMEOUT=10
YAHOO_FINANCE_RETRIES=3

# Data Paths
TICKERS_CONFIG_PATH=config/tickers_seed_top50.csv
DATA_OUTPUT_DIR=data/
NOTEBOOKS_DIR=notebooks/

# Historical Data Settings
HISTORICAL_LOOKBACK_DAYS=252
HISTORICAL_INTERVAL=1d

# Intraday Data Settings
INTRADAY_INTERVAL=5m
INTRADAY_LOOKBACK_DAYS=5

# Trend Calculation Windows (in business days)
TREND_WINDOW_1=1
TREND_WINDOW_2=3
TREND_WINDOW_3=9

# Trend Weights
TREND_WEIGHT_1=0.50
TREND_WEIGHT_2=0.30
TREND_WEIGHT_3=0.20

# Target Price Multipliers
BUY_TARGET_MULTIPLIER=0.5
SELL_TARGET_MULTIPLIER=0.5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/vkp_wonder.log

# Development
DEBUG=False
ENVIRONMENT=development